ata:function(){return{contentOptions:{jobDescription:"Check your portfolio’s job fit",jfcResult:"Result & suggestions",previousResults:"Previous matches"},activeContent:"jobDescription",jobTitle:"",jobCompany:"",jobDescription:"",jobDescriptionHtml:"",generationError:!1,cancelGeneration:!1,isJobTitleMissing:!1,isJobCompanyMissing:!1,jobFitResult:null,isGenerateChecklistModalOpen:!1,loadState:null,loadSteps:{analyzing:[{id:1,text:"Loading your portfolio..."},{id:2,text:"Scanning portfolio structure..."},{id:3,text:"Extracting case studies and project details..."},{id:4,text:"Parsing job description..."},{id:5,text:"Identifying portfolio sections..."},{id:6,text:"Extracting project titles and descriptions..."},{id:7,text:"Extracting testimonials and social proof..."},{id:8,text:"Identifying portfolio call-to-actions..."},{id:9,text:"Checking for missing sections..."},{id:10,text:"Extracting key job requirements..."},{id:11,text:"Checking for relevant keywords..."},{id:12,text:"Assessing experience alignment..."}],returnToEditor:[{id:1,text:"Extracting key gaps..."},{id:2,text:"Refining insights for your next steps..."},{id:3,text:"Bringing the insights into the editor..."},{id:4,text:"Almost there..."},{id:5,text:"Finalizing the checklist..."}],duplicating:[{id:1,text:"Transferring images and media..."},{id:2,text:"Cloning text and custom sections..."},{id:3,text:"Copying your portfolio structure..."},{id:4,text:"Preserving layout and design..."},{id:5,text:"Setting up your duplicate..."},{id:6,text:"Finalising duplicate..."},{id:7,text:"Your portfolio copy is almost ready..."}]},draft:"About UXfolio\nAt UXfolio, we empower UX and product designers by providing a platform to create stunning portfolios that stand out to hiring managers. Our team is passionate about building intuitive, design-centric tools that streamline the hiring process and showcase designers’ best work.\n\nWe’re looking for a Product Designer to help shape the future of UXfolio. If you’re passionate about user experience, love solving design challenges, and thrive in a fast-moving SaaS environment, we’d love to hear from you!\n\nResponsibilities\n\t•\tDesign end-to-end user experiences, from concept to final implementation.\n\t•\tConduct user research and usability testing to inform design decisions.\n\t•\tCollaborate with product managers, engineers, and other designers to ship impactful features.\n\t•\tDevelop wireframes, prototypes, and high-fidelity UI designs.\n\t•\tMaintain and evolve our design system for consistency and scalability.\n\t•\tIterate based on user feedback, data insights, and business goals.\n\t•\tEnsure accessibility and usability best practices are met in all designs.\n\nRequired Skills\n\t•\tStrong visual and interaction design skills.\n\t•\tProficiency in Figma and design system methodologies.\n\t•\tAbility to conduct user research and translate insights into design improvements.\n\t•\tExperience designing for SaaS or B2B platforms.\n\t•\tStrong understanding of UX principles, usability heuristics, and accessibility standards.\n\t•\tExcellent collaboration and communication skills.\n\nPreferred Skills\n\t•\tExperience with motion design and microinteractions.\n\t•\tKnowledge of HTML/CSS (you won’t code, but understanding feasibility is key).\n\t•\tFamiliarity with AI-driven design tools and workflows.\n\t•\tExperience working with analytics tools like Hotjar, Mixpanel, or Amplitude.\n\nExperience Level\nMid-Level (3–5 years of experience in product/UX design).\n\nIndustries\nSaaS, B2B, Design Tools, Hiring & Recruitment.\n\nEducation & Certifications\n\t•\tDegree in Design, HCI, or a related field is a plus, but not required.\n\t•\tRelevant certifications (e.g., Google UX Design Certificate) are a bonus.\n\nSoftware & Tools\n\t•\tFigma (primary design tool)\n\t•\tMiro (for collaboration and brainstorming)\n\t•\tNotion (for documentation and design specs)\n\t•\tJira (for project management)\n\t•\tHotjar or Mixpanel (for user analytics)\n\nKeywords\nUser-Centered Design, SaaS, B2B, UX Research, Wireframes, Prototyping, Design Systems, Accessibility, User Testing, Data-Driven Design, Cross-Functional Collaboration.\n\nCompany Values & Culture\nAt UXfolio, we believe in designing with empathy, iterating fast, and learning continuously. Our remote-first culture fosters flexibility, ownership, and a strong focus on collaboration. We encourage innovation and provide opportunities for professional growth.\n\nCompensation & Benefits\n\t•\tCompetitive salary (EUR 50,000–65,000/year, based on experience)\n\t•\tFlexible working hours and remote work\n\t•\tAnnual learning budget for courses, conferences, and books\n\t•\tTeam retreats and offsite meetups\n\t•\tHome office setup allowance\n\nApplication Process\n\t•\tSubmit your resume and portfolio via our application portal.\n\t•\tShortlisted candidates will complete a design challenge (paid).\n\t•\tFinal stage: A chat with our team to discuss culture fit and ways of working.",userPortfolios:[],deletingId:null}},mounted:function(){var e=this;return tr(Qn().m(function t(){var n;return Qn().w(function(t){for(;;)switch(t.n){case 0:return t.n=1,Rn.A.getPortfolios(e.viewData.loggedInUserId);case 1:n=t.v,e.userPortfolios=n.data;case 2:return t.a(2)}},t)}))()},methods:{getPortfolioName:function(e){return this.userPortfolios.find(function(t){return t.shortId===e||t._id.endsWith(e)}).name},closeGenerator:function(){this.loadState=null,this.generationError=!1},retryGeneration:function(){this.generationError=!1,this.loadState="analyzing",this.handleSubmit()},stopGeneration:function(){this.cancelGeneration=!0,this.closeGenerator()},setJobDescription:function(e){this.promptError=!1,this.jobDescription=e},setJobDescriptionHtml:function(e){this.jobDescriptionHtml=e},handleUseDraftClicked:function(){this.jobTitle="Product Designer",this.jobCompany="UXfolio"},handleSidebarChange:function(e){var t=this;"jobDescription"===e&&(this.jobTitle="",this.jobCompany="",this.jobDescrip